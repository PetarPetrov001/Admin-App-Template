# Only needed for initial app installation (OAuth flow).
# After install, the access token is stored in prisma/dev.sqlite
# and other developers don't need this file at all.
SHOPIFY_API_KEY=your-client-id-from-partners-dashboard
SHOPIFY_API_SECRET=your-client-secret-from-partners-dashboard
SHOPIFY_APP_URL=https://your-tunnel-url.ngrok-free.dev
PORT=3000
